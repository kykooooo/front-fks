# .env.local.example
# Copier ce fichier en .env.local et remplir les valeurs réelles.
# .env.local est dans .gitignore — ne jamais commiter les vraies valeurs.
#
# ⚠️ IMPORTANT : les variables EXPO_PUBLIC_* sont embarquées dans le bundle JS
# du client et donc EXTRACTIBLES. N'y mettre que des identifiants publics
# (URL backend, clé Firebase web). PAS de secret backend ici.
#
# L'auth backend se fait via Firebase ID token uniquement (Authorization: Bearer).
# La clé statique EXPO_PUBLIC_BACKEND_API_KEY a été retirée.
#
# Pour les builds EAS (cloud) :
#   eas secret:create --scope project --name EXPO_PUBLIC_BACKEND_URL --value "..."
#   eas secret:create --scope project --name EXPO_PUBLIC_FIREBASE_API_KEY --value "..."
#   eas secret:create --scope project --name EXPO_PUBLIC_SENTRY_DSN --value "..."

EXPO_PUBLIC_BACKEND_URL=https://fks-backend-xmnb.onrender.com
EXPO_PUBLIC_FIREBASE_API_KEY=<votre_cle_firebase_web>
EXPO_PUBLIC_SENTRY_DSN=<votre_dsn_sentry>
