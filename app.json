{
  "expo": {
    "name": "fks-apps",
    "slug": "fks-apps",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.fks.app",
      "buildNumber": "1",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.fks.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.1045688248623-c60323f37nmrhlh4574kmstv4t8v46gd"
        }
      ],
      ["@sentry/react-native/expo", { "url": "https://sentry.io/" }]
    ],
    "extra": {
      "SENTRY_DSN": "",
      "AMPLITUDE_API_KEY": "",
      "eas": {
        "projectId": "607ef5fa-ce96-4c07-9643-b79885aa28a3"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/607ef5fa-ce96-4c07-9643-b79885aa28a3"
    }
  }
}
