{
  "cli": {
    "version": ">= 10.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "testers": {
      "distribution": "internal",
      "autoIncrement": true,
      "environment": "production",
      "channel": "testers",
      "ios": {
        "resourceClass": "m-medium",
        "image": "latest"
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "NO_FLIPPER": "1"
      }
    },
    "testflight": {
      "distribution": "store",
      "autoIncrement": true,
      "environment": "production",
      "channel": "testflight",
      "cache": {
        "disabled": true
      },
      "ios": {
        "resourceClass": "m-medium",
        "image": "latest"
      },
      "env": {
        "NO_FLIPPER": "1"
      }
    },
    "android-preview": {
      "distribution": "internal",
      "autoIncrement": true,
      "environment": "production",
      "channel": "production",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "distribution": "store",
      "autoIncrement": true,
      "environment": "production",
      "channel": "production"
    }
  },
  "submit": {
    "testflight": {
      "ios": {
        "appleTeamId": "2Z868K5P3V",
        "ascAppId": "6746264443"
      }
    },
    "production": {
      "ios": {
        "appleTeamId": "2Z868K5P3V"
      }
    }
  }
}
