rules_version = "2";
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isClubOwner(clubId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/clubs/$(clubId)).data.ownerUid == request.auth.uid;
    }

    function isCoach(clubId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/clubs/$(clubId)/members/$(request.auth.uid)).data.role == "coach";
    }

    function clubIdForUser(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.clubId;
    }

    function isCoachOfUser(userId) {
      return isSignedIn() &&
        clubIdForUser(userId) != null &&
        isCoach(clubIdForUser(userId));
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isCoachOfUser(userId);
      allow create, update: if isOwner(userId);
      allow delete: if false;

      match /sessions/{sessionId} {
        allow read: if isOwner(userId) || isCoachOfUser(userId);
        allow write: if isOwner(userId);
      }

      match /plannedSessions/{sessionId} {
        allow read: if isOwner(userId) || isCoachOfUser(userId);
        allow write: if isOwner(userId);
      }
    }

    match /clubs/{clubId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isClubOwner(clubId);
      allow delete: if false;

      match /members/{memberId} {
        allow read: if isOwner(memberId) || isCoach(clubId);
        allow create, update: if isOwner(memberId) && (
          request.resource.data.role == "player" ||
          (request.resource.data.role == "coach" && isClubOwner(clubId))
        );
        // Un membre peut se retirer lui-même, ou le owner du club peut retirer n'importe qui
        allow delete: if isOwner(memberId) || isClubOwner(clubId);
      }
    }
  }
}
