  "devDependencies": {
    "@react-native/eslint-config": "^0.82.1",
    "@types/react": "~19.1.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.3.3",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=18"
